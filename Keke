local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local BASE_URL = "https://catalog.roblox.com/v1/search/items?category=Avatar&limit=30"

-- cache item để random rộng hơn
local cachedItems = {}
local nextCursor = nil

local function clearAccessories(char)
	for _, v in pairs(char:GetChildren()) do
		if v:IsA("Accessory") then
			v:Destroy()
		end
	end
end

-- lấy thêm item từ marketplace
local function fetchItems()
	local url = BASE_URL
	if nextCursor then
		url = url .. "&cursor=" .. nextCursor
	end

	local success, response = pcall(function()
		return HttpService:GetAsync(url)
	end)

	if not success then return end

	local data = HttpService:JSONDecode(response)
	if not data or not data.data then return end

	for _, item in pairs(data.data) do
		if item.id then
			table.insert(cachedItems, item.id)
		end
	end

	nextCursor = data.nextPageCursor
end

-- đảm bảo có đủ item để random
local function getRandomAccessoryId()
	if #cachedItems < 50 then
		for i = 1, 3 do
			fetchItems()
			task.wait(0.2)
		end
	end

	if #cachedItems == 0 then return nil end

	return cachedItems[math.random(1, #cachedItems)]
end

local function addRandomAccessory(char)
	local humanoid = char:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	clearAccessories(char)

	local assetId = getRandomAccessoryId()
	if not assetId then return end

	local success, objects = pcall(function()
		return game:GetObjects("rbxassetid://" .. assetId)
	end)

	if success and objects and #objects > 0 then
		local obj = objects[1]

		if obj:IsA("Accessory") then
			humanoid:AddAccessory(obj)
			return
		end

		local acc = obj:FindFirstChildWhichIsA("Accessory", true)
		if acc then
			humanoid:AddAccessory(acc)
		end
	end
end

local function setupPlayer(player)
	player.CharacterAdded:Connect(function(char)
		task.spawn(function()
			while char and char.Parent do
				addRandomAccessory(char)
				task.wait(10)
			end
		end)
	end)
end

-- preload vài page đầu cho random rộng
task.spawn(function()
	for i = 1, 5 do
		fetchItems()
		task.wait(0.3)
	end
end)

for _, p in pairs(Players:GetPlayers()) do
	setupPlayer(p)
end

Players.PlayerAdded:Connect(setupPlayer)
