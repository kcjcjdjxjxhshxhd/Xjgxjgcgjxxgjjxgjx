local function tweenFov(fov)

	if currentFovTween then
		currentFovTween:Cancel()
	end

	currentFovTween = TweenService:Create(
		camera,
		TweenInfo.new(
			0.35,
			Enum.EasingStyle.Quint,
			Enum.EasingDirection.Out
		),
		{
			FieldOfView = fov
		}
	)

	currentFovTween:Play()
end

