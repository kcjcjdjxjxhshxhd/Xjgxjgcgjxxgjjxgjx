--------------------------------------------------
-- BLUR LOOP
--------------------------------------------------

local blurAnimating = false

local function startBlurLoop()

	if blurAnimating then
		return
	end

	blurAnimating = true

	task.spawn(function()

		while exhausted do

			--------------------------------------------------
			-- FADE IN
			--------------------------------------------------

			blur.Enabled = true

			local tween1 = TweenService:Create(
				blur,
				TweenInfo.new(
					0.8,
					Enum.EasingStyle.Sine,
					Enum.EasingDirection.Out
				),
				{
					Size = 18
				}
			)

			tween1:Play()
			tween1.Completed:Wait()

			if not exhausted then
				break
			end

			--------------------------------------------------
			-- FADE OUT
			--------------------------------------------------

			local tween2 = TweenService:Create(
				blur,
				TweenInfo.new(
					0.8,
					Enum.EasingStyle.Sine,
					Enum.EasingDirection.Out
				),
				{
					Size = 8
				}
			)

			tween2:Play()
			tween2.Completed:Wait()
		end

		--------------------------------------------------
		-- REMOVE BLUR
		--------------------------------------------------

		local removeTween = TweenService:Create(
			blur,
			TweenInfo.new(0.45),
			{
				Size = 0
			}
		)

		removeTween:Play()

		removeTween.Completed:Wait()

		blur.Enabled = false

		blurAnimating = false
	end)
end

--------------------------------------------------
-- AUTO SPEED CHECK
--------------------------------------------------

local function updateSpeed()

	changingSpeed = true

	if exhausted then

		hum.WalkSpeed =
			math.max(
				0,
				walkSpeed - EXHAUST_SPEED_PENALTY
			)

	elseif sprinting then

		hum.WalkSpeed = sprintSpeed

	else

		hum.WalkSpeed = walkSpeed
	end

	task.defer(function()
		changingSpeed = false
	end)
end

--------------------------------------------------
-- ANTI SERVER SPEED CHANGE XD
--------------------------------------------------

local antiSpeedConnection

local function setupAntiSpeed()

	if antiSpeedConnection then
		antiSpeedConnection:Disconnect()
	end

	antiSpeedConnection =
		RunService.RenderStepped:Connect(function()

		if not hum then
			return
		end

		if changingSpeed then
			return
		end

		local targetSpeed

		--------------------------------------------------
		-- exhausted
		--------------------------------------------------

		if exhausted then

			targetSpeed =
				math.max(
					0,
					walkSpeed - EXHAUST_SPEED_PENALTY
				)

		--------------------------------------------------
		-- sprinting
		--------------------------------------------------

		elseif sprinting then

			targetSpeed = sprintSpeed

		else
			return
		end

		--------------------------------------------------
		-- server Ä‘á»•i speed -> kÃ©o láº¡i XD
		--------------------------------------------------

		if hum.WalkSpeed ~= targetSpeed then

			changingSpeed = true

			hum.WalkSpeed = targetSpeed

			task.defer(function()
				changingSpeed = false
			end)
		end
	end)
end

setupAntiSpeed()

