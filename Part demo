local function partToTool(part)

	local prompt = part:FindFirstChildOfClass("ProximityPrompt")
	if prompt then
		prompt.Enabled = false
	end

	local tool = Instance.new("Tool")
	tool.Name = "Part"
	tool.TextureId = "rbxassetid://74964015260212"
	tool:SetAttribute("IsPart", true)

	local handle = part:Clone()
	handle.Name = "Handle"

	local p = handle:FindFirstChildOfClass("ProximityPrompt")
	if p then
		p:Destroy()
	end

	handle.Parent = tool

	setupToolAnimation(tool)

	-- ===== CHECK PART LIMIT =====

	local partCount = 0

	for _,t in pairs(backpack:GetChildren()) do
		if t:IsA("Tool") and t.Name == "Part" then
			partCount += 1
		end
	end

	for _,t in pairs(character:GetChildren()) do
		if t:IsA("Tool") and t.Name == "Part" then
			partCount += 1
		end
	end

	-- nếu đã đủ 10
	if partCount >= 10 then
		
		if #inventory >= maxSlots then
			
			showInventoryFull()

			-- bật lại prompt để player nhặt sau
			if prompt then
				prompt.Enabled = true
			end

			return
