local function getHealFromPart(part)

	local size = part.Size
	local volume = size.X * size.Y * size.Z

	-- normal part
	if volume < 50 then
		return 0.1
	end

	-- small / medium
	if volume < 200 then
		return volume * 0.002
	end

	-- big part
	return volume * 0.001

end

