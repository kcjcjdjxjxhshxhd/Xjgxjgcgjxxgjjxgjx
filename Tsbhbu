	safeWarn.TextColor3 = Color3.new(1,1,1)
	safeWarn.Font = Enum.Font.GothamBlack
	safeWarn.TextSize = 20
	safeWarn.TextTransparency = 0

	local stroke = Instance.new("UIStroke", safeWarn)
	stroke.Color = Color3.fromRGB(0,0,0)
	stroke.Thickness = 2

	-- ðŸ”» LOOP FADE
	task.spawn(function()
		while safeWarn and safeWarn.Parent do
			local fadeOut = TweenService:Create(safeWarn, TweenInfo.new(3), {
				TextTransparency = 1
