local listVisible = false

local function refreshLayout(animated)
	local base = listVisible and posWithList or posNoList
	local tweenInfo = TweenInfo.new(0.25)

	local function move(obj, y)
		local goal = {Position = UDim2.new(0.1, 0, 0, y)}

		if animated then
			TweenService:Create(obj, tweenInfo, goal):Play()
		else
			obj.Position = goal.Position
		end
	end

	-- main buttons
	move(startBtn, base.start)
	move(stopBtn, base.stop)
	move(autoBtn, base.auto)
	move(typeBox, base.type)

	local extraOffset = 40

	-- slider
	if targetType == "Orbit" then
		sliderVisible = true
		sliderFrame.Visible = true
		move(sliderFrame, base.type + 35)
		extraOffset = 75
	else
		sliderVisible = false
		sliderFrame.Visible = false
	end

	-- buttons below
	move(autoSwitch, base.type + extraOffset)
	move(noFriendBtn, base.type + extraOffset + 45)
	move(hopBtn, base.type + extraOffset + 80)
move(safeBtn, base.type + extraOffset + 115)
end

