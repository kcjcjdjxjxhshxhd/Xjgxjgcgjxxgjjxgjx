		txt.TextScaled = true
		
		currentBillboard = bill
	end
end

local function getLowest()
	local low=nil
	local hp=math.huge

	for _,p in pairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character then
			
			-- ðŸ”» lá»c friend náº¿u báº­t
			if noFriends and LocalPlayer:IsFriendsWith(p.UserId) then
				continue
			end

			local h = p.Character:FindFirstChildOfClass("Humanoid")
			if h and h.Health > 0 and h.Health < hp then
				hp = h.Health
				low = p
			end
		end
	end

	return low
end

