local function getPartValue(part)

	local size = part.Size.X
	local value = 0

	-- BIG PART
	if size >= 1.5 then

		local minSize = 1.5
		local maxSize = 15

		local minValue = 3
		local maxValue = 50

		local t = math.clamp((size - minSize) / (maxSize - minSize),0,1)
		
		if part:GetAttribute("Mutated") then
	value *= 10
end

		value = minValue + (maxValue - minValue) * t


	-- SMALL PART
	elseif size < 1 then

		local minSize = 0.01
		local maxSize = 0.99

		local minValue = 0.01
		local maxValue = 0.5

		local t = math.clamp((size - minSize) / (maxSize - minSize),0,1)

		value = minValue + (maxValue - minValue) * t


	-- NORMAL PART
	else
		value = 1
	end


	-- PARTICLE BONUS
	local particle =
		part:FindFirstChildOfClass("Smoke") or
		part:FindFirstChildOfClass("Fire") or
		part:FindFirstChildOfClass("Sparkles") or
		part:FindFirstChildOfClass("PointLight")

	if particle then

		if particle:IsA("Smoke") or particle:IsA("Fire") then
			value += particle.Size * 0.25

		elseif particle:IsA("PointLight") then
			value += particle.Range / 30

		elseif particle:IsA("Sparkles") then
			value += 0.15
		end

	end


	-- MULTIPLIERS

	-- Neon material
	if part.Material == Enum.Material.Neon then
		value *= 2
	end

	-- PointLight multiplier
	local light = part:FindFirstChildOfClass("PointLight")
	if light then
		value *= 1.5
	end


	-- ðŸ”’ LIMIT VALUE (ANTI ECONOMY BREAK)
	value = math.clamp(value,0,100)

	return value

end

