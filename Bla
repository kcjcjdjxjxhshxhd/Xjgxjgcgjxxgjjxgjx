local function makeMutated(part)

	part:SetAttribute("Mutated",true)

	part.Material = Enum.Material.Neon

	local fire = Instance.new("Fire")
	fire.Parent = part

	local smoke = Instance.new("Smoke")
	smoke.Parent = part

	local spark = Instance.new("Sparkles")
	spark.Parent = part

	local light = Instance.new("PointLight")
	light.Brightness = 5
	light.Range = 20
	light.Parent = part

	task.spawn(function()

		while part and part.Parent do
			task.wait(0.3)

			randomShape(part)

			local color = randomColor()

			for _,v in ipairs(part:GetChildren()) do

				if v:IsA("Fire") then
					v.Color = color
					v.SecondaryColor = randomColor()

				elseif v:IsA("Smoke") then
					v.Color = color

				elseif v:IsA("Sparkles") then
					v.SparkleColor = color

				elseif v:IsA("PointLight") then
					v.Color = color
				end

			end

		end

	end)

end

