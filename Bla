-- PARTICLES
local particles = {
	"Smoke",
	"Sparkles",
	"Fire",
	"PointLight"
}

local function randomMaterial(part)
part.Material = materials[math.random(1,#materials)]
end

local function randomParticle(part)

	if math.random(1,100) > 40 then
		return nil
	end

	local particleName = particles[math.random(1,#particles)]

	local particle = Instance.new(particleName)
	particle.Parent = part

	local size = part.Size.X
	local scale = math.clamp(size / 5, 0.2, 5)

	local pColor = randomColor()

	if particleName == "Smoke" then
		particle.RiseVelocity = 5 * scale
		particle.Size = scale
		particle.Color = Color3.new(pColor.R, pColor.G, pColor.B)

	elseif particleName == "Fire" then
		particle.Heat = 5 * scale
		particle.Size = scale
		particle.Color = Color3.new(pColor.R, pColor.G, pColor.B)
		particle.SecondaryColor = randomColor()

	elseif particleName == "Sparkles" then
	particle.SparkleColor = pColor
	elseif particleName == "PointLight" then

	particle.Color = pColor

	local brightness = math.clamp(size / 2, 0.2, 10)
	local range = math.clamp(size * 2, 3, 40)

	particle.Brightness = brightness
	particle.Range = range
end

	return particleName

end

updateParticleSize = function(part)

	local size = part.Size.X
	local scale = math.clamp(size / 5, 0.2, 5)

	local smoke = part:FindFirstChildOfClass("Smoke")
	if smoke then
		smoke.Size = scale
		smoke.RiseVelocity = 5 * scale
	end

	local fire = part:FindFirstChildOfClass("Fire")
	if fire then
		fire.Size = scale
		fire.Heat = 5 * scale
	end
	
	local light = part:FindFirstChildOfClass("PointLight")
if light then
	light.Brightness = math.clamp(size / 2, 0.2, 10)
	light.Range = math.clamp(size * 2, 3, 40)
end

end

local function randomFloat(min,max)
return min + math.random()*(max-min)
end

